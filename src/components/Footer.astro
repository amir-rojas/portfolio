---

<footer class="footer" id="contact" aria-label="Contact and site info">
  <div class="footer-grid-bg" aria-hidden="true"></div>

  <div class="footer-inner">
    <p class="footer-eyebrow" data-i18n="footer.eyebrow">Contact</p>
    <div class="footer-cta">
      <p class="footer-headline">
        <span class="footer-hl-line" data-i18n="footer.headingLine1">Let's build</span>
        <span class="footer-hl-line footer-hl-accent" data-i18n="footer.headingLine2">something.</span>
      </p>
      <p class="footer-tagline" data-i18n="footer.tagline">
        Whether it's a new product, a tricky problem to solve, or just a good conversation — I'm always up for it.
      </p>
    </div>

    <div class="footer-rule" role="separator" aria-hidden="true"></div>

    <div class="footer-body">
      <div class="footer-col">
        <p class="footer-label" data-i18n="footer.sayHello">Say hello</p>
        <a class="footer-email" href="mailto:amirbellido@gmail.com">
          amirbellido@gmail.com
          <span class="footer-email-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="footer-col footer-col--right">
        <p class="footer-label" data-i18n="footer.findMe">Find me</p>
        <nav class="footer-social" aria-label="Social links">
          <a href="https://github.com/amir-rojas" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.23c-3.34.73-4.03-1.41-4.03-1.41-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.7.8.58C20.56 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
            </svg>
            GitHub <span aria-hidden="true">↗</span>
          </a>
          <a href="https://www.linkedin.com/in/amirrojasbellido/" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 0 1-2.06-2.06 2.06 2.06 0 1 1 2.06 2.06zm1.78 13.02H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.27V1.73C24 .77 23.2 0 22.22 0z"/>
            </svg>
            LinkedIn <span aria-hidden="true">↗</span>
          </a>
        </nav>
      </div>
    </div>

  </div>

  <div class="footer-bar">
    <div class="footer-bar-inner">
      <span class="footer-copy">© 2026 Amir Rojas</span>
      <span class="footer-credit"><span data-i18n="footer.madeBy">made by</span> <span class="footer-credit-ar">AR</span></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg-1);
    scroll-margin-top: 60px;
    overflow: hidden;
  }

  /* Subtle grid — same pattern as hero-grid, anchors the footer visually */
  .footer-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 44px 44px;
    /* Fade grid toward the top so it doesn't compete with the content above */
    mask-image: radial-gradient(ellipse 120% 80% at 50% 110%, black 40%, transparent 75%);
    pointer-events: none;
  }

  .footer-inner {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 1440px;
    margin: 0 auto;
    padding: 5rem 6rem 4rem;
    width: 100%;
  }

  .footer-eyebrow {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-mute);
    margin: 0 0 2.5rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-eyebrow::before {
    content: '';
    width: 16px;
    height: 1px;
    background: var(--neon-1);
    box-shadow: 0 0 6px var(--neon-1);
    flex-shrink: 0;
  }

  .footer-cta {
    margin-bottom: 3rem;
  }

  .footer-tagline {
    margin: 1.25rem 0 0;
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--fg-dim);
    max-width: 34rem;
    line-height: 1.65;
  }


  .footer-headline {
    margin: 0;
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .footer-hl-line {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  .footer-hl-accent {
    background: linear-gradient(120deg, var(--neon-1), var(--neon-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .footer-rule {
    height: 1px;
    background: var(--surface-mid);
    margin: 2.5rem 0;
  }

  .footer-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .footer-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    color: var(--fg-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.875rem 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-label::before {
    content: '';
    width: 16px;
    height: 1px;
    background: var(--neon-1);
    box-shadow: 0 0 6px var(--neon-1);
    flex-shrink: 0;
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--fg-dim);
    text-decoration: none;
    transition: color var(--t-fast) var(--ease);
  }

  .footer-email-arrow {
    display: inline-block;
    transition: transform var(--t-fast) var(--ease);
  }

  .footer-email:hover {
    color: var(--neon-1);
  }

  .footer-email:hover .footer-email-arrow {
    transform: translateX(5px);
  }

  .footer-col--right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer-social {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2.5rem;
  }

  .footer-social a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color var(--t-fast) var(--ease);
  }

  .footer-social a:hover {
    color: var(--neon-1);
  }

  .footer-bar {
    position: relative;
    border-top: 1px solid var(--border-glass);
  }

  .footer-bar-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 1.25rem 6rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy,
  .footer-credit {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--fg-mute);
  }

  .footer-credit-ar {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.55rem;
    color: var(--neon-1);
    letter-spacing: 0.05em;
    vertical-align: middle;
  }

  @media (max-width: 860px) {
    .footer { min-height: 0; }
    .footer-inner { padding: 4rem 2rem 3rem; }
    .footer-bar-inner { padding: 1.25rem 2rem; }
  }

  @media (max-width: 600px) {
    .footer-inner {
      padding: 4rem 1.25rem 3rem;
    }

    .footer-bar-inner {
      padding: 1.25rem 1.25rem;
    }

    .footer-social {
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }
</style>
