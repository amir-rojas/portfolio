---

<nav class="nav">
  <a class="nav-logo" href="/">AR</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<script>
  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', () => {
      document.documentElement.classList.add('is-nav-scrolling');
    });
  });

  window.addEventListener('scrollend', () => {
    document.documentElement.classList.remove('is-nav-scrolling');
  }, { passive: true });

  let navScrollFallback: ReturnType<typeof setTimeout> | null = null;
  window.addEventListener('scroll', () => {
    if (!document.documentElement.classList.contains('is-nav-scrolling')) return;
    if (navScrollFallback) clearTimeout(navScrollFallback);
    navScrollFallback = setTimeout(() => {
      document.documentElement.classList.remove('is-nav-scrolling');
      navScrollFallback = null;
    }, 400);
  }, { passive: true });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 60px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-logo {
    font-family: "JetBrains Mono", monospace;
    font-size: 1rem;
    font-weight: 500;
    color: var(--neon-1);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--fg-dim);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color var(--t-fast) var(--ease);
  }

  .nav-links a:hover {
    color: var(--fg);
  }
</style>
