---
import { Image } from 'astro:assets';
import heroPreview from '../../assets/screenshots/hero-preview.png';
---

<section class="pp" id="portfolio-personal">
  <div class="pp-pin">
    <div class="pp-stage">

      <!-- Columna izquierda: título + pasos -->
      <div class="pp-copy">
        <div class="eyebrow">Portfolio</div>
        <h2>Designing<br /><span class="accent">this very site.</span></h2>
        <p class="pp-lede">
          A meta project — documenting the process of thinking, deciding and
          building the portfolio you're reading right now.
        </p>

        <div class="pp-track">
          <div class="pp-rail" aria-hidden="true">
            <div class="pp-rail-fill"></div>
          </div>
          <div class="pp-steps">
            <div class="pp-step is-active" data-step="0">
              <span class="idx mono">[ 01 ]</span>
              <div class="body">
                <span class="lbl">Research</span>
                <span class="desc">Framework search · design references · Claude Design</span>
              </div>
            </div>
            <div class="pp-step" data-step="1">
              <span class="idx mono">[ 02 ]</span>
              <div class="body">
                <span class="lbl">Decision — Why Astro?</span>
                <span class="desc">Decision log · real trade-offs · new territory</span>
              </div>
            </div>
            <div class="pp-step" data-step="2">
              <span class="idx mono">[ 03 ]</span>
              <div class="body">
                <span class="lbl">Result</span>
                <span class="desc">The live hero section</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna derecha: paneles visuales -->
      <div class="pp-canvas">

        <!-- Panel 0 — Inspiración: browser + chat -->
        <div class="pp-panel is-active" data-panel="0">
          <div class="pp-browser">
            <div class="browser-bar">
              <span class="tl"></span><span class="tl"></span><span class="tl"></span>
              <div class="browser-tabs">
                <div class="tab is-active mono">google · framework portfolio</div>
                <div class="tab mono">claude design</div>
              </div>
              <div class="browser-url mono">⌕ google.com/search</div>
            </div>
            <div class="browser-body">
              <div class="search-bar">
                <span class="g-mark mono">G</span>
                <span class="search-q mono">best framework for portfolio website</span>
                <span class="search-x mono">×</span>
              </div>
              <div class="search-list">
                <div class="search-q-row">
                  <span class="ico mono">⌕</span>
                  <span class="txt mono">best framework for portfolio website</span>
                  <span class="meta mono">3 min ago</span>
                </div>
                <div class="search-q-row">
                  <span class="ico mono">⌕</span>
                  <span class="txt mono">astro framework what is it</span>
                  <span class="meta mono">18 min ago</span>
                </div>
                <div class="search-q-row">
                  <span class="ico mono">⌕</span>
                  <span class="txt mono">dark mode portfolio design inspiration</span>
                  <span class="meta mono">36 min ago</span>
                </div>
                <div class="search-q-row">
                  <span class="ico mono">⌕</span>
                  <span class="txt mono">awwwards portfolio scroll animation</span>
                  <span class="meta mono">44 min ago</span>
                </div>
              </div>
              <div class="browser-divider">
                <span class="mono">↳ after 1h · opened Claude Design</span>
              </div>
              <div class="chat-block">
                <div class="chat-hdr mono">
                  <span class="ai-dot"></span>claude design · portfolio
                </div>
                <div class="chat-msg me">
                  <span class="who mono">you</span>
                  <div class="bubble">
                    design my developer portfolio in dark mode. modern, editorial feel.
                    warm orange accent. not a generic dev site.
                  </div>
                </div>
                <div class="chat-msg ai">
                  <span class="who mono">claude</span>
                  <div class="bubble">
                    v1 ↓<br />
                    <span class="li"><b>1.</b> Black + warm orange · large editorial type · monospace metadata</span>
                    <span class="li"><b>2.</b> Scroll storytelling — each project told step by step</span>
                    <span class="li"><b>3.</b> IDE aesthetic: eyebrows, dashes, high-contrast details</span>
                    <span class="li dim">went with this one →</span>
                  </div>
                </div>
                <div class="chat-typing mono">
                  <span class="d"></span><span class="d"></span><span class="d"></span>
                  <span class="lbl">generating v2, v3, v4…</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel 1 — Decisión: terminal decision log -->
        <div class="pp-panel" data-panel="1">
          <div class="pp-terminal">
            <div class="term-bar">
              <span class="tl"></span><span class="tl"></span><span class="tl"></span>
              <span class="term-title mono">~ /portfolio/docs · decision-log.md</span>
              <span class="term-status mono">● grabando</span>
            </div>
            <div class="term-body mono">
              <div class="cm"># decision: framework for the portfolio</div>
              <div class="cm"># date: 2026-04 · author: amir</div>
              <div class="sp"></div>
              <div class="kw">## options evaluated</div>
              <div><span class="tx">- react</span>    <span class="cm">// recently used · too comfortable, no learning</span></div>
              <div><span class="tx">- angular</span>  <span class="cm">// too heavy for a static portfolio</span></div>
              <div><span class="tx">- astro</span>    <span class="hl">// ← chosen</span></div>
              <div class="sp"></div>
              <div class="kw">## reasons</div>
              <div class="reason">
                <span class="chk">✓</span><span class="vl">Built for content-driven sites</span>
                <div class="cmt"><span class="cm">// portfolio = perfect fit</span></div>
              </div>
              <div class="reason">
                <span class="chk">✓</span><span class="vl">Apple-style scroll animations</span>
                <div class="cmt"><span class="cm">// works natively, no extra library</span></div>
              </div>
              <div class="reason">
                <span class="chk">✓</span><span class="vl">Zero JS by default</span>
                <div class="cmt"><span class="cm">// fast without fighting the framework</span></div>
              </div>
              <div class="reason">
                <span class="chk">✓</span><span class="vl">Never used it before</span>
                <div class="cmt"><span class="cm">// real learning, not comfort zone</span></div>
              </div>
              <div class="sp"></div>
              <div class="kw">## status</div>
              <div>→ <span class="ok">RESOLVED</span> · <span class="cm">in progress</span><span class="blink">▮</span></div>
            </div>
          </div>
        </div>

        <!-- Panel 2 — Result: live hero preview -->
        <div class="pp-panel" data-panel="2">
          <div class="pp-result">
            <div class="result-preview">
              <div class="preview-tag mono">→ live result</div>
              <Image
                src={heroPreview}
                alt="Portfolio hero section — live result"
                class="hero-screenshot"
              />
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const section = document.querySelector('#portfolio-personal');
  const ppPin = section?.querySelector('.pp-pin') ?? null;
  const ppSteps = section ? Array.from(section.querySelectorAll('.pp-step')) : [];
  const ppPanels = section ? Array.from(section.querySelectorAll('.pp-panel')) : [];
  const ppRailFill = section?.querySelector('.pp-rail-fill') ?? null;

  function updatePP() {
    if (!ppPin) return;
    const r = ppPin.getBoundingClientRect();
    const vh = window.innerHeight;
    const total = r.height - vh;
    const passed = Math.min(Math.max(-r.top, 0), total);
    const p = total > 0 ? passed / total : 0;

    let stage = 0;
    if (p >= 0.67) stage = 2;
    else if (p >= 0.34) stage = 1;

    ppSteps.forEach((el, idx) => {
      el.classList.toggle('is-active', idx === stage);
      el.classList.toggle('is-done', idx < stage);
    });
    ppPanels.forEach((el, idx) => {
      el.classList.toggle('is-active', idx === stage);
    });

    if (ppRailFill) {
      const fill = Math.min(100, Math.max(6, p * 100));
      (ppRailFill as HTMLElement).style.setProperty('--prog', fill.toFixed(1) + '%');
    }
  }

  if (!window.matchMedia('(max-width: 860px)').matches) {
    window.addEventListener('scroll', updatePP, { passive: true });
    updatePP();
  }
</script>

<style>
  .pp { position: relative; padding: 0; }

  .pp-pin {
    height: 320vh;
    position: relative;
    isolation: isolate;
  }
  .pp-pin::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 30%, rgba(255, 107, 53, 0.05), transparent 50%),
      radial-gradient(circle at 90% 80%, rgba(255, 184, 0, 0.03), transparent 50%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 100%);
    pointer-events: none;
    z-index: -1;
  }

  .pp-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(420px, 520px) 1fr;
    align-items: center;
    overflow: hidden;
  }

  .pp-copy {
    padding: 0 56px 0 96px;
    position: relative;
    z-index: 2;
  }
  .pp-copy .eyebrow {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-mute);
    margin: 0 0 22px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pp-copy .eyebrow::before {
    content: '';
    width: 22px;
    height: 1px;
    background: var(--neon-1);
    box-shadow: 0 0 8px var(--neon-1);
    flex-shrink: 0;
  }
  .pp-copy h2 {
    font-size: clamp(38px, 4.6vw, 60px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 18px;
  }
  .pp-copy h2 .accent {
    background: linear-gradient(120deg, var(--neon-1), var(--neon-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .pp-lede {
    color: var(--fg-dim);
    font-size: 15px;
    line-height: 1.65;
    max-width: 42ch;
    margin: 0 0 36px;
  }

  .pp-track {
    position: relative;
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 18px;
  }
  .pp-rail {
    position: relative;
    width: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 8px auto;
    justify-self: center;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 18%, black 82%, transparent 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 18%, black 82%, transparent 100%);
  }
  .pp-rail-fill {
    position: absolute;
    top: 0;
    left: -0.5px;
    width: 2px;
    background: linear-gradient(to bottom, var(--neon-1), var(--neon-2));
    height: var(--prog, 0%);
    box-shadow: 0 0 12px rgba(255, 107, 53, 0.7);
    transition: height 0.15s cubic-bezier(0.22, 0.61, 0.36, 1);
    border-radius: 2px;
  }
  .pp-steps { display: flex; flex-direction: column; gap: 14px; }
  .pp-step {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.015);
    opacity: 0.32;
    transform: translateX(-6px);
    transition:
      opacity 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      border-color 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      background 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 480ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .pp-step.is-active {
    opacity: 1;
    transform: translateX(0);
    border-color: rgba(255, 107, 53, 0.45);
    background: linear-gradient(160deg, rgba(255, 107, 53, 0.08), rgba(255, 107, 53, 0.02));
    box-shadow:
      0 0 0 1px rgba(255, 107, 53, 0.15) inset,
      0 0 32px rgba(255, 107, 53, 0.18),
      0 0 64px rgba(255, 107, 53, 0.08);
  }
  .pp-step.is-done { opacity: 0.62; }
  .pp-step .idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--neon-1);
    letter-spacing: 0.1em;
    min-width: 30px;
    padding-top: 2px;
  }
  .pp-step .body { display: flex; flex-direction: column; gap: 4px; }
  .pp-step .lbl { font-size: 15px; font-weight: 500; letter-spacing: -0.01em; }
  .pp-step .desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--fg-mute);
    letter-spacing: 0.02em;
  }

  .pp-canvas { position: relative; height: 100%; padding: 70px 48px 70px 48px; }
  .pp-panel {
    position: absolute;
    inset: 70px 48px 70px 48px;
    display: grid;
    place-items: center;
    opacity: 0;
    transform: translateY(18px) scale(0.97);
    filter: blur(6px);
    transition:
      opacity 0.55s cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.55s cubic-bezier(0.22, 0.61, 0.36, 1);
    pointer-events: none;
  }
  .pp-panel.is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
    pointer-events: auto;
  }

  /* Chrome compartido */
  .pp-browser, .pp-terminal, .result-code {
    width: 100%;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: linear-gradient(160deg, #111111, #060606);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 30px 80px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(255, 107, 53, 0.05);
    overflow: hidden;
  }
  .browser-bar, .term-bar, .code-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
  }
  .browser-bar .tl, .term-bar .tl, .code-bar .tl {
    width: 9px; height: 9px; border-radius: 50%; background: #ff5f57; flex-shrink: 0;
  }
  .browser-bar .tl:nth-child(2), .term-bar .tl:nth-child(2), .code-bar .tl:nth-child(2) { background: #febc2e; }
  .browser-bar .tl:nth-child(3), .term-bar .tl:nth-child(3), .code-bar .tl:nth-child(3) { background: #28c840; }

  /* Panel 0 — Browser */
  .pp-browser { max-width: 760px; }
  .browser-tabs { display: flex; gap: 6px; margin-left: 10px; }
  .browser-tabs .tab {
    font-size: 10px; padding: 5px 10px; border-radius: 6px;
    color: var(--fg-mute); letter-spacing: 0.02em; border: 1px solid transparent;
  }
  .browser-tabs .tab.is-active {
    color: var(--fg);
    background: rgba(255, 107, 53, 0.08);
    border-color: rgba(255, 107, 53, 0.25);
  }
  .browser-url {
    margin-left: auto; font-size: 10px; color: var(--fg-mute);
    padding: 5px 10px; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px; background: rgba(0,0,0,0.3); letter-spacing: 0.02em;
  }
  .browser-body { padding: 22px 24px 24px; display: flex; flex-direction: column; gap: 16px; }
  .search-bar {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px; background: rgba(255,255,255,0.02);
  }
  .g-mark { font-weight: 700; font-size: 14px; color: var(--neon-1); }
  .search-q { flex: 1; font-size: 13px; color: var(--fg); letter-spacing: 0; }
  .search-x { color: var(--fg-mute); font-size: 14px; }
  .search-list { display: flex; flex-direction: column; gap: 2px; padding-top: 4px; }
  .search-q-row {
    display: grid; grid-template-columns: 16px 1fr auto;
    gap: 12px; align-items: center; padding: 8px 4px;
    font-size: 12px; border-bottom: 1px dashed rgba(255,255,255,0.08);
  }
  .search-q-row .ico { color: var(--fg-mute); font-size: 11px; }
  .search-q-row .txt { color: var(--fg-dim); letter-spacing: 0; }
  .search-q-row:first-child .txt { color: var(--neon-1); }
  .search-q-row .meta { color: #3a3a3d; font-size: 9px; letter-spacing: 0.06em; }
  .browser-divider {
    display: flex; align-items: center; gap: 12px;
    font-size: 10px; color: var(--fg-mute); letter-spacing: 0.08em; margin: 2px 0;
  }
  .browser-divider::before, .browser-divider::after {
    content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.08);
  }
  .chat-block {
    border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
    padding: 14px; background: rgba(0,0,0,0.35);
    display: flex; flex-direction: column; gap: 10px;
  }
  .chat-hdr {
    font-size: 10px; letter-spacing: 0.08em; color: var(--fg-mute);
    display: flex; align-items: center; gap: 8px;
    padding-bottom: 8px; border-bottom: 1px dashed rgba(255,255,255,0.08);
  }
  .ai-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--neon-1); box-shadow: 0 0 8px var(--neon-1);
  }
  .chat-msg { display: grid; grid-template-columns: 36px 1fr; gap: 10px; align-items: flex-start; }
  .chat-msg .who {
    font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--fg-mute); padding: 6px 0;
  }
  .chat-msg.ai .who { color: var(--neon-1); }
  .chat-msg .bubble {
    font-size: 12.5px; line-height: 1.55; padding: 9px 12px;
    border-radius: 10px; background: rgba(255,255,255,0.035);
    border: 1px solid rgba(255,255,255,0.08); color: var(--fg);
  }
  .chat-msg.ai .bubble {
    background: rgba(255,107,53,0.06); border-color: rgba(255,107,53,0.2);
  }
  .chat-msg .bubble .li { display: block; font-size: 12px; color: var(--fg-dim); padding: 2px 0; }
  .chat-msg .bubble .li b { color: var(--neon-2); font-weight: 600; }
  .chat-msg .bubble .li.dim { color: var(--fg-mute); font-style: italic; }
  .chat-typing {
    display: flex; align-items: center; gap: 8px;
    padding-left: 46px; font-size: 10px; color: var(--fg-mute); letter-spacing: 0.04em;
  }
  .chat-typing .d {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--neon-1); opacity: 0.5;
    animation: chatDot 1.2s ease-in-out infinite;
  }
  .chat-typing .d:nth-child(2) { animation-delay: 0.15s; }
  .chat-typing .d:nth-child(3) { animation-delay: 0.3s; }
  @keyframes chatDot {
    0%, 100% { opacity: 0.25; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(-2px); }
  }

  /* Panel 1 — Terminal */
  .pp-terminal { max-width: 760px; background: linear-gradient(160deg, #0d0a07, #060606); }
  .term-title { font-size: 10px; color: var(--fg-dim); letter-spacing: 0.04em; margin-left: 8px; }
  .term-status { margin-left: auto; font-size: 9px; color: #ff3d68; letter-spacing: 0.1em; }
  .term-body { padding: 22px 26px 26px; font-size: 12px; line-height: 1.7; color: var(--fg-dim); }
  .term-body .cm { color: var(--fg-mute); }
  .term-body .kw { color: var(--neon-2); margin-top: 6px; letter-spacing: 0.02em; }
  .term-body .tx { color: var(--fg); }
  .term-body .hl { color: var(--neon-1); font-weight: 500; }
  .term-body .vl { color: var(--fg); font-weight: 500; }
  .term-body .sp { height: 8px; }
  .term-body .reason {
    display: grid; grid-template-columns: 18px 1fr;
    align-items: baseline; gap: 4px 8px;
  }
  .term-body .reason .cmt { grid-column: 2; }
  .term-body .chk { color: var(--neon-1); font-weight: 700; text-shadow: 0 0 6px rgba(255,107,53,0.6); }
  .term-body .ok {
    color: #4ade80; background: rgba(74,222,128,0.1);
    padding: 1px 8px; border-radius: 4px;
    border: 1px solid rgba(74,222,128,0.3);
    font-size: 10px; letter-spacing: 0.1em;
  }
  .blink { display: inline-block; margin-left: 6px; color: var(--neon-1); animation: cursorBlink 1s steps(2) infinite; }
  @keyframes cursorBlink { 50% { opacity: 0; } }

  /* Panel 2 — Result */
  .pp-result { width: 100%; max-width: 900px; }
  .result-preview { display: flex; flex-direction: column; gap: 10px; }
  .preview-tag { font-size: 10px; letter-spacing: 0.1em; color: var(--neon-1); padding-left: 4px; }
  .hero-screenshot {
    width: 100%; height: auto; display: block;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255, 107, 53, 0.06);
  }

  /* Disable transitions during nav anchor scroll */
  :global(html.is-nav-scrolling) .pp-step,
  :global(html.is-nav-scrolling) .pp-panel,
  :global(html.is-nav-scrolling) .pp-rail-fill {
    transition: none !important;
  }

  /* Responsive */
  @media (max-width: 1180px) {
    .pp-copy { padding: 0 32px 0 48px; }
    .pp-canvas { padding: 70px 24px 70px 24px; }
    .pp-panel { inset: 70px 24px 70px 24px; }
    .pp-stage { grid-template-columns: minmax(360px, 460px) 1fr; }
  }
  @media (max-width: 860px) {
    .pp-stage { grid-template-columns: 1fr; height: auto; padding: 80px 0 60px; gap: 24px; }
    .pp-pin { height: auto; }
    .pp-copy { padding: 0 20px; }
    .pp-rail { display: none; }
    .pp-track { grid-template-columns: 1fr; }
    .pp-step { opacity: 1 !important; transform: none !important; }
    .pp-step.is-active {
      border-color: rgba(255, 255, 255, 0.08) !important;
      background: rgba(255, 255, 255, 0.015) !important;
      box-shadow: none !important;
    }
    .pp-canvas { padding: 0 20px 60px; height: auto; display: flex; flex-direction: column; gap: 20px; }
