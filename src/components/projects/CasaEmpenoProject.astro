---
import { Image } from 'astro:assets';
import toxdosDash from '../../assets/screenshots/toxdos-dash.png';
---

<section class="ce" id="casa-empeno">
  <div class="ce-pin">
    <div class="ce-stage">

      <!-- Columna izquierda: título + pasos -->
      <div class="ce-copy">
        <div class="eyebrow">02 / Toxdos</div>
        <h2>A pawnshop,<br /><span class="accent">gone digital.</span></h2>
        <p class="ce-lede">
          Full management system for a real pawnshop in Bolivia — contracts,
          interest, cash sessions, clients and sales. Built from scratch,
          shipped to production in March 2026.
        </p>

        <div class="ce-steps">
          <div class="ce-step is-active" data-step="0">
            <span class="idx mono">[ 01 ]</span>
            <div class="body">
              <span class="lbl">The Problem</span>
              <span class="desc">Real client · paper-based · Potosí, Bolivia</span>
            </div>
          </div>
          <div class="ce-step" data-step="1">
            <span class="idx mono">[ 02 ]</span>
            <div class="body">
              <span class="lbl">Architecture</span>
              <span class="desc">Screaming Architecture · domain per module</span>
            </div>
          </div>
          <div class="ce-step" data-step="2">
            <span class="idx mono">[ 03 ]</span>
            <div class="body">
              <span class="lbl">In Production</span>
              <span class="desc">Live · Cloudflare + Render + Supabase</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Columna derecha: cartas apiladas -->
      <div class="ce-canvas">
        <div class="ce-stack" data-stage="0">

          <!-- Capa 0 — The Problem: project brief -->
          <div class="ce-layer l0">
            <span class="layer-tag mono"><span class="ltdot"></span>project brief</span>
            <div class="brief-body">
              <div class="client-rows">
                <div class="client-row">
                  <span class="client-label mono">CLIENT</span>
                  <span class="client-val">Benjamín · Potosí, Bolivia</span>
                </div>
                <div class="client-row">
                  <span class="client-label mono">TYPE</span>
                  <span class="client-val">Pawnshop management system</span>
                </div>
              </div>
              <div class="brief-divider"></div>
              <div class="brief-section">
                <div class="sec-hdr mono">## the problem</div>
                <p class="sec-text">
                  Tracking contracts, interest payments and item inventory on paper.
                  No visibility into due dates, cash flow or customer history.
                </p>
              </div>
              <div class="brief-divider"></div>
              <div class="brief-section">
                <div class="sec-hdr mono">## domain entities</div>
                <div class="dom-list">
                  <div class="dom-item">
                    <span class="dom-dot"></span>
                    <span class="dom-name">Empeños</span>
                    <span class="dom-desc mono">// pawn contracts with expiry</span>
                  </div>
                  <div class="dom-item">
                    <span class="dom-dot"></span>
                    <span class="dom-name">Intereses</span>
                    <span class="dom-desc mono">// whole months, not fractions</span>
                  </div>
                  <div class="dom-item">
                    <span class="dom-dot"></span>
                    <span class="dom-name">Caja</span>
                    <span class="dom-desc mono">// cash sessions · open / close</span>
                  </div>
                  <div class="dom-item">
                    <span class="dom-dot"></span>
                    <span class="dom-name">Clientes</span>
                    <span class="dom-desc mono">// customer registry</span>
                  </div>
                  <div class="dom-item">
                    <span class="dom-dot"></span>
                    <span class="dom-name">Ventas</span>
                    <span class="dom-desc mono">// sale of unredeemed items</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Capa 1 — Architecture: terminal -->
          <div class="ce-layer l1">
            <span class="layer-tag mono"><span class="ltdot"></span>architecture</span>
            <div class="term-body mono">
              <div class="cm"># structure mirrors the business, not the framework</div>
              <div class="sp"></div>
              <div><span class="dir">modules/</span></div>
              <div>├─ <span class="dir">pawns/</span>         <span class="cm">← core domain</span></div>
              <div>├─ <span class="dir">payments/</span>      <span class="cm">// interest · monthly blocks</span></div>
              <div>├─ <span class="dir">cash-sessions/</span> <span class="cm">// open · close · movements</span></div>
              <div>├─ <span class="dir">customers/</span>     <span class="cm">// client registry</span></div>
              <div>├─ <span class="dir">sales/</span>         <span class="cm">// unredeemed item sales</span></div>
              <div>├─ <span class="dir">expenses/</span>      <span class="cm">// operational costs</span></div>
              <div>└─ <span class="dir">dashboard/</span>     <span class="cm">// metrics · KPIs</span></div>
              <div class="sp"></div>
              <div class="kw">## pattern (each module)</div>
              <div class="chain">
                <span class="chain-step">router</span>
                <span class="chain-arr">→</span>
                <span class="chain-step">controller</span>
                <span class="chain-arr">→</span>
                <span class="chain-step">service</span>
                <span class="chain-arr">→</span>
                <span class="chain-step hl">repository</span>
              </div>
              <div class="cm chain-note">// SQL lives in repository only</div>
              <div class="sp"></div>
              <div class="kw">## key decision</div>
              <div>
                <span class="tx">interest</span> = <span class="hl">whole months</span>
                <span class="cm"> // matches real bolivian pawnshop policy</span>
              </div>
            </div>
          </div>

          <!-- Capa 2 — In Production: screenshot real -->
          <div class="ce-layer l2">
            <span class="layer-tag mono"><span class="ltdot live"></span>live · mar 2026</span>
            <div class="result-body">
              <Image
                src={toxdosDash}
                alt="Toxdos dashboard — pawnshop management system in production"
                class="ce-screenshot"
              />
              <div class="result-footer mono">
                <span class="dep-strip">
                  <span class="dep-item">Cloudflare Pages</span>
                  <span class="dep-sep">+</span>
                  <span class="dep-item">Render</span>
                  <span class="dep-sep">+</span>
                  <span class="dep-item">Supabase</span>
                </span>
                <span class="badge-wip">🚧 multi-sucursal</span>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const section = document.querySelector('#casa-empeno');
  const cePin   = section?.querySelector('.ce-pin') ?? null;
  const ceStack = section?.querySelector('.ce-stack') as HTMLElement | null;
  const ceSteps = section ? Array.from(section.querySelectorAll('.ce-step')) : [];

  function updateCE() {
    if (!cePin || !ceStack) return;
    const r     = cePin.getBoundingClientRect();
    const vh    = window.innerHeight;
    const total = r.height - vh;
    const p     = total > 0 ? Math.min(Math.max(-r.top, 0), total) / total : 0;

    let stage = 0;
    if (p >= 0.67) stage = 2;
    else if (p >= 0.34) stage = 1;

    ceStack.dataset.stage = String(stage);
    ceSteps.forEach((el, idx) => {
      el.classList.toggle('is-active', idx === stage);
      el.classList.toggle('is-done', idx < stage);
    });
  }

  window.addEventListener('scroll', updateCE, { passive: true });
  updateCE();
</script>

<style>
  .ce { position: relative; padding: 0; }

  .ce-pin {
    height: 320vh;
    position: relative;
    isolation: isolate;
  }
  .ce-pin::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 25%, rgba(255, 107, 53, 0.05), transparent 50%),
      radial-gradient(circle at 10% 80%, rgba(255, 184, 0, 0.03), transparent 50%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 100%);
    pointer-events: none;
    z-index: -1;
  }

  .ce-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(420px, 520px) 1fr;
    align-items: center;
    overflow: hidden;
  }

  /* ── Copy (left) ─────────────────────────────────── */
  .ce-copy { padding: 0 56px 0 96px; }

  .ce-copy .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-mute);
    margin: 0 0 22px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ce-copy .eyebrow::before {
    content: '';
    width: 22px;
    height: 1px;
    background: var(--neon-1);
    box-shadow: 0 0 8px var(--neon-1);
  }
  .ce-copy h2 {
    font-size: clamp(38px, 4.6vw, 60px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.02;
    margin: 0 0 18px;
  }
  .ce-copy h2 .accent {
    background: linear-gradient(120deg, var(--neon-1), var(--neon-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .ce-lede {
    color: var(--fg-dim);
    font-size: 15px;
    line-height: 1.65;
    max-width: 42ch;
    margin: 0 0 36px;
  }

  .ce-steps { display: flex; flex-direction: column; gap: 12px; }
  .ce-step {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.015);
    opacity: 0.32;
    transform: translateX(-6px);
    transition:
      opacity 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      border-color 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      background 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 480ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .ce-step.is-active {
    opacity: 1;
    transform: translateX(0);
    border-color: rgba(255, 107, 53, 0.45);
    background: linear-gradient(160deg, rgba(255, 107, 53, 0.08), rgba(255, 107, 53, 0.02));
    box-shadow:
      0 0 0 1px rgba(255, 107, 53, 0.15) inset,
      0 0 32px rgba(255, 107, 53, 0.18),
      0 0 64px rgba(255, 107, 53, 0.08);
  }
  .ce-step.is-done { opacity: 0.62; }
  .ce-step .idx {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--neon-1);
    letter-spacing: 0.1em;
    min-width: 30px;
    padding-top: 2px;
  }
  .ce-step .body { display: flex; flex-direction: column; gap: 4px; }
  .ce-step .lbl  { font-size: 15px; font-weight: 500; letter-spacing: -0.01em; }
  .ce-step .desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--fg-mute);
    letter-spacing: 0.02em;
  }

  /* ── Canvas + Stack (right) ──────────────────────── */
  .ce-canvas {
    position: relative;
    height: 100%;
    display: grid;
    place-items: center;
  }

  .ce-stack {
    position: relative;
    width: 800px;
    height: 620px;
  }

  .ce-layer {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(160deg, #111111, #060606);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 24px 64px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 107, 53, 0.04);
    overflow: hidden;
    transform-origin: center center;
    will-change: transform, opacity;
    transition:
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      opacity   0.5s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* layer tag badge */
  .layer-tag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--neon-1);
    background: rgba(0, 0, 0, 0.7);
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255, 107, 53, 0.28);
    backdrop-filter: blur(4px);
  }
  .ltdot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--neon-1);
    box-shadow: 0 0 6px var(--neon-1);
    flex-shrink: 0;
  }
  .ltdot.live {
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: livePulse 2s ease-in-out infinite;
  }
  @keyframes livePulse { 0%,100%{opacity:1} 50%{opacity:0.35} }

  /* ── Stage transforms (3 layers) ─────────────────── */
  .ce-stack[data-stage="0"] .ce-layer.l0 {
    transform: translate(0, 0) scale(1) rotate(0deg);
    opacity: 1;
  }
  .ce-stack[data-stage="0"] .ce-layer.l1,
  .ce-stack[data-stage="0"] .ce-layer.l2 {
    transform: translate(40px, 40px) scale(0.86);
    opacity: 0;
  }

  .ce-stack[data-stage="1"] .ce-layer.l0 {
    transform: translate(-82px, -28px) scale(0.92) rotate(-2deg);
    opacity: 0.9;
  }
  .ce-stack[data-stage="1"] .ce-layer.l1 {
    transform: translate(0, 0) scale(1) rotate(0deg);
    opacity: 1;
  }
  .ce-stack[data-stage="1"] .ce-layer.l2 {
    transform: translate(40px, 40px) scale(0.86);
    opacity: 0;
  }

  .ce-stack[data-stage="2"] .ce-layer.l0 {
    transform: translate(-130px, -60px) scale(0.80) rotate(-4deg);
    opacity: 0.5;
  }
  .ce-stack[data-stage="2"] .ce-layer.l1 {
    transform: translate(-18px, 55px) scale(0.87) rotate(3deg);
    opacity: 0.78;
  }
  .ce-stack[data-stage="2"] .ce-layer.l2 {
    transform: translate(0, 0) scale(1) rotate(0deg);
    opacity: 1;
  }

  /* ── Layer 0 — Brief ─────────────────────────────── */
  .brief-body {
    padding: 52px 26px 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    height: 100%;
    box-sizing: border-box;
  }
  .client-rows { display: flex; flex-direction: column; gap: 8px; }
  .client-row {
    display: grid;
    grid-template-columns: 58px 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .client-label {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }
  .client-val { font-size: 13px; color: var(--fg); font-weight: 500; }

  .brief-divider { height: 1px; background: rgba(255,255,255,0.07); }

  .brief-section { display: flex; flex-direction: column; gap: 8px; }
  .sec-hdr { font-size: 10px; letter-spacing: 0.06em; color: var(--neon-2); }
  .sec-text { font-size: 12.5px; line-height: 1.6; color: var(--fg-dim); margin: 0; }

  .dom-list { display: flex; flex-direction: column; gap: 6px; }
  .dom-item { display: flex; align-items: center; gap: 10px; }
  .dom-dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--neon-1); box-shadow: 0 0 5px var(--neon-1);
    flex-shrink: 0;
  }
  .dom-name { font-size: 13px; font-weight: 500; color: var(--fg); min-width: 70px; }
  .dom-desc { font-size: 10.5px; color: var(--fg-mute); letter-spacing: 0.02em; }

  /* ── Layer 1 — Terminal ──────────────────────────── */
  .term-body {
    padding: 52px 26px 26px;
    font-size: 11.5px;
    line-height: 1.75;
    color: var(--fg-dim);
    height: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }
  .term-body .cm  { color: var(--fg-mute); }
  .term-body .kw  { color: var(--neon-2); }
  .term-body .dir { color: var(--neon-2); }
  .term-body .tx  { color: var(--fg); }
  .term-body .hl  { color: var(--neon-1); font-weight: 500; }
  .term-body .sp  { height: 6px; }

  .chain {
    display: flex;
    align-items: center;
    gap: 5px;
    margin: 5px 0 2px;
    flex-wrap: wrap;
  }
  .chain-step {
    font-size: 11px;
    color: var(--fg);
    padding: 2px 7px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    background: rgba(255,255,255,0.03);
  }
  .chain-step.hl {
    color: var(--neon-1);
    border-color: rgba(255,107,53,0.35);
    background: rgba(255,107,53,0.06);
  }
  .chain-arr  { color: var(--fg-mute); font-size: 11px; }
  .chain-note { font-size: 10px; }

  /* ── Layer 2 — Result ────────────────────────────── */
  .result-body {
    padding: 48px 18px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    height: 100%;
    box-sizing: border-box;
  }
  .ce-screenshot {
    width: 100%;
    flex: 1;
    min-height: 0;
    object-fit: cover;
    object-position: top;
    display: block;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .result-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .dep-strip {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--fg-mute);
  }
  .dep-item { color: var(--fg-dim); }
  .dep-sep  { color: var(--fg-mute); }
  .badge-wip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.05em;
    color: var(--neon-2);
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid rgba(255,184,0,0.3);
    background: rgba(255,184,0,0.06);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1180px) {
    .ce-copy { padding: 0 32px 0 48px; }
    .ce-stack { width: 600px; height: 480px; }
  }
  @media (max-width: 860px) {
    .ce-stage {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 100vh;
      padding: 80px 0;
      gap: 24px;
    }
    .ce-pin { height: auto; }
    .ce-canvas { height: 380px; }
    .ce-stack { width: 90%; max-width: 480px; height: 320px; }
    .ce-layer { transform: none !important; opacity: 1 !important; }
    .ce-layer.l0,
    .ce-layer.l1 { display: none; }
    .ce-stack[data-stage="0"] .ce-layer.l0,
    .ce-stack[data-stage="1"] .ce-layer.l1,
    .ce-stack[data-stage="2"] .ce-layer.l2 {
      display: block;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
