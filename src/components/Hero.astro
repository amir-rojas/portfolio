<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 32px 80px;
    overflow: hidden;
  }

  /* Blob de fondo */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(255, 107, 53, 0.12), transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(255, 61, 104, 0.1), transparent 40%);
    filter: blur(40px);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Tag pill */
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--fg-dim);
    letter-spacing: 0.06em;
    margin-bottom: 36px;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
  }

  /* Punto pulsante verde */
  .pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.85);
    }
  }

  /* Título grande */
  .hero-title {
    font-size: clamp(56px, 10vw, 120px);
    line-height: 0.92;
    letter-spacing: -0.045em;
    font-weight: 600;
    margin: 0 0 28px;
    color: var(--fg);
  }

  /* Segunda línea con gradiente */
  .accent {
    display: block;
    background: linear-gradient(120deg, var(--neon-1) 0%, var(--neon-2) 50%, var(--neon-3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Bio */
  .hero-sub {
    max-width: 580px;
    margin: 0 auto 48px;
    font-size: clamp(16px, 1.4vw, 19px);
    color: var(--fg-dim);
    line-height: 1.6;
  }

  /* Botones */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    background: var(--fg);
    color: #000;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    transition: all var(--t-fast) var(--ease);
    text-decoration: none;
  }

  .btn-primary:hover {
    background: var(--neon-1);
    box-shadow: 0 0 32px rgba(255, 107, 53, 0.4);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 14px 22px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    font-size: 14px;
    color: var(--fg);
    transition: all var(--t-fast) var(--ease);
    text-decoration: none;
  }

  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.04);
  }

  /* Iconos flotantes */
  .hero-icons {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .float-icon {
    position: absolute;
    width: 72px;
    height: 72px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.01));
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    animation: float 8s ease-in-out infinite;
  }

  .float-icon svg {
    width: 50%;
    height: 50%;
  }

  /* Posición de cada icono */
  .fi-angular {
    top: 20%;
    left: 10%;
    animation-delay: -1s;
  }
  .fi-react {
    top: 25%;
    right: 12%;
    animation-delay: -4s;
  }
  .fi-node {
    bottom: 25%;
    left: 14%;
    animation-delay: -7s;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotateZ(-3deg);
    }
    25% {
      transform: translateY(-16px) rotateZ(2deg);
    }
    50% {
      transform: translateY(-6px) rotateZ(5deg);
    }
    75% {
      transform: translateY(-20px) rotateZ(-2deg);
    }
  }
</style>
