---

---

<section class="hero">
  <!-- 1. Tag pill -->
  <div class="hero-tag">
    <span class="pulse"></span>
    <span>DISPONIBLE PARA NUEVOS PROYECTOS · LATAM / REMOTO</span>
  </div>

  <!-- 2. Título en dos líneas, segunda con clase accent -->
  <h1 class="hero-title">
    Amir Rojas<br />
    <span class="accent">Full-Stack Developer.</span>
  </h1>

  <!-- 3. Bio -->
  <p class="hero-sub">
    Construyo sistemas web y móviles con arquitecturas limpias, interfaces fluidas y una obsesión
    por la calidad del detalle. Angular, React, Ionic, Node.
  </p>

  <!-- 4. CTAs envueltos en un div -->
  <div class="hero-cta">
    <a href="#projects" class="btn-primary">
      <span>Ver proyectos</span>
      <span>→</span>
    </a>
    <a href="#contact" class="btn-ghost">Contactar</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 32px 80px;
    overflow: hidden;
  }

  /* Blob de fondo */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(255, 107, 53, 0.12), transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(255, 61, 104, 0.1), transparent 40%);
    filter: blur(40px);
    pointer-events: none;
  }

  /* Tag pill */
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--fg-dim);
    letter-spacing: 0.06em;
    margin-bottom: 36px;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
  }

  /* Punto pulsante verde */
  .pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.85);
    }
  }

  /* Título grande */
  .hero-title {
    font-size: clamp(56px, 10vw, 120px);
    line-height: 0.92;
    letter-spacing: -0.045em;
    font-weight: 600;
    margin: 0 0 28px;
    color: var(--fg);
  }

  /* Segunda línea con gradiente */
  .accent {
    display: block;
    background: linear-gradient(120deg, var(--neon-1) 0%, var(--neon-2) 50%, var(--neon-3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Bio */
  .hero-sub {
    max-width: 580px;
    margin: 0 auto 48px;
    font-size: clamp(16px, 1.4vw, 19px);
    color: var(--fg-dim);
    line-height: 1.6;
  }

  /* Botones */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    background: var(--fg);
    color: #000;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    transition: all var(--t-fast) var(--ease);
  }

  .btn-primary:hover {
    background: var(--neon-1);
    box-shadow: 0 0 32px rgba(255, 107, 53, 0.4);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 14px 22px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    font-size: 14px;
    color: var(--fg);
    transition: all var(--t-fast) var(--ease);
  }

  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.04);
  }
</style>
